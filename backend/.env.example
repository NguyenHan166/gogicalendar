NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
LOG_PRETTY=true

# MongoDB Atlas URI. Keep real credentials only in .env or a secret manager.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority&appName=GogiCalendar
MONGODB_DB_NAME=gogicalendar
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=0

CORS_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=gogi-calendar-backend
JWT_AUDIENCE=gogi-calendar-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
REFRESH_COOKIE_NAME=refresh_token
BCRYPT_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MS=900000
MANAGER_LOGIN_RATE_LIMIT_WINDOW_MS=900000
MANAGER_LOGIN_RATE_LIMIT_MAX=10
EMPLOYEE_LOGIN_RATE_LIMIT_WINDOW_MS=900000
EMPLOYEE_LOGIN_RATE_LIMIT_MAX=5

SEED_DEMO_DATA=false
SEED_MANAGER_ID=1054413
SEED_MANAGER_NAME=Gogi Calendar Manager
SEED_MANAGER_PHONE=0900000000
SEED_MANAGER_USERNAME=rm4650
# Required only when SEED_DEMO_DATA=true. Never commit a real password.
SEED_MANAGER_PASSWORD=
